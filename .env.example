# —— 本機開發（預設僅瀏覽器 localStorage，各裝置資料獨立）——
# VITE_STORAGE_MODE=localStorage

# —— Vercel 正式環境（多端共用同一份業務資料）——
# 建置時注入前端；請與伺服器 API_SYNC_TOKEN 設為相同強隨機字串
VITE_STORAGE_MODE=remote
VITE_API_URL=
VITE_API_SYNC_TOKEN=請改成長隨機密鑰

# Vercel 後端（Project → Settings → Environment Variables）
# API_SYNC_TOKEN=（與 VITE_API_SYNC_TOKEN 相同）
# Vercel → Marketplace → Upstash Redis 連結專案後會注入：
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# （若使用舊版 KV 整合，亦支援 KV_REST_API_URL / KV_REST_API_TOKEN）
