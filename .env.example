# —— 本機開發（預設僅瀏覽器 localStorage，各裝置資料獨立）——
# VITE_STORAGE_MODE=localStorage

# —— Vercel 正式／預覽（多端共用同一份業務資料）——
# 注意：VITE_* 在建置時寫入 JS，改動後必須 Redeploy（不能只改變數不重建）
VITE_STORAGE_MODE=remote
# 留空即可（同源 /api）；勿填完整網址除非 API 在別網域
VITE_API_URL=
# 與下方 API_SYNC_TOKEN 必須完全相同（建議 32+ 字元隨機）
VITE_API_SYNC_TOKEN=

# —— Vercel 後端（Serverless，執行時讀取）——
# API_SYNC_TOKEN=（與 VITE_API_SYNC_TOKEN 相同）

# —— Upstash 透過 Vercel 整合自動注入 ——
# api/sync-bundle.js 使用 REDIS_URL（與東山鴨頭相同，Vercel 安裝 Upstash 後通常會有）
# REDIS_URL=

# 以下為 REST 客戶端用（舊版 api/_lib 測試用），正式 sync-bundle.js 以 REDIS_URL 為準：
# KV_REST_API_URL、KV_REST_API_TOKEN
