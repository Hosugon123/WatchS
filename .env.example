# —— 本機開發（預設僅瀏覽器 localStorage，各裝置資料獨立）——
# VITE_STORAGE_MODE=localStorage

# —— Vercel 正式／預覽（多端共用同一份業務資料）——
# 注意：VITE_* 在建置時寫入 JS，改動後必須 Redeploy（不能只改變數不重建）
VITE_STORAGE_MODE=remote
# 留空即可（同源 /api）；勿填完整網址除非 API 在別網域
VITE_API_URL=
# 與下方 API_SYNC_TOKEN 必須完全相同（建議 32+ 字元隨機）
VITE_API_SYNC_TOKEN=

# —— Vercel 後端（Serverless，執行時讀取）——
# API_SYNC_TOKEN=（與 VITE_API_SYNC_TOKEN 相同）

# —— Upstash 透過 Vercel 整合自動注入（擇一組即可，程式兩種都支援）——
# KV_REST_API_URL=          ← 你目前畫面上的名稱，正確
# KV_REST_API_TOKEN=        ← 請用「可寫入」的 token，不要用 READ_ONLY 那組
# UPSTASH_REDIS_REST_URL=    ← 與 KV_REST_API_URL 擇一，不必兩套都手動加
# UPSTASH_REDIS_REST_TOKEN=

# 以下為整合附帶，本專案 sync-bundle 不使用，可忽略：
# REDIS_URL、KV_URL、KV_REST_API_READ_ONLY_TOKEN
